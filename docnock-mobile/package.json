{
  "name": "docnock",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "prepare": "husky",
    "format": "prettier --write .",
    "spell-check": "cspell \"src/**/*.{js,ts,tsx}\"",
    "postinstall": "patch-package && cd ios && pod install && cd ..",
    "android:build-apk": "cd android && ./gradlew assembleRelease && open ./app/build/outputs/apk/release",
    "release": "cd android && ./gradlew app:assembleRelease",
    "clean": "cd android && ./gradlew clean && cd ..",
    "uninstallAll": "cd android && ./gradlew uninstallAll && cd .."
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --max-warnings=1"
    ]
  },
