# MapTiler API Key for 3D terrain and buildings
# Get a free key at https://cloud.maptiler.com/account/keys/
# Free tier: 100k requests/month
VITE_MAPTILER_KEY=your_maptiler_api_key_here

# CesiumJS Ion token (optional — basic globe works without it)
# Get a free token at https://ion.cesium.com/tokens
VITE_CESIUM_TOKEN=

# Google Maps API Key for Photorealistic 3D Tiles (optional)
# Enable "Map Tiles API" at https://console.cloud.google.com
VITE_GOOGLE_MAPS_KEY=
