# =============================================================================
# SCENSUS Cloud Deployment — Environment Variables
# =============================================================================
# Copy this file to .env and fill in all required values before deploying.
# DO NOT commit .env to version control.
# =============================================================================

# ---------- Required ----------

# PostgreSQL password for the 'scensus' database user
POSTGRES_PASSWORD=

# HMAC secret for bridge/electron API authentication (min 32 chars recommended)
HMAC_SECRET=

# JWT secret for user authentication (min 32 chars, must differ from HMAC_SECRET)
JWT_SECRET=

# ---------- TLS Certificates ----------
# Place fullchain.pem and privkey.pem in cloud/certs/
# For self-signed dev certs:
#   openssl req -x509 -nodes -days 365 -newkey rsa:2048 \
#     -keyout cloud/certs/privkey.pem -out cloud/certs/fullchain.pem \
#     -subj "/CN=scensus.local"

# ---------- Optional ----------

# Deployment environment: "production" or "development"
# In production, missing secrets will cause a hard startup error.
ENVIRONMENT=production

# CORS allowed origins (comma-separated, default: * for development only)
# Example: https://scensus.example.com,https://admin.scensus.example.com
CORS_ORIGINS=*

# Log level: debug, info, warning, error
LOG_LEVEL=info

# Port mappings (change if defaults conflict)
HTTPS_PORT=443
HTTP_PORT=80
